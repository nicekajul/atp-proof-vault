# --- App ---
PORT=4000
APP_BASE_URL=http://localhost:5173
NODE_ENV=development

# --- Google Apps Script proxy (Sheets database + Drive file storage) ---
# From the Web App deployment of /apps-script/Code.gs (bound to your Sheet).
# See SETUP.md.
APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXXXXXX/exec
APPS_SCRIPT_SECRET=replace-with-a-long-random-secret

# --- JWT ---
JWT_SECRET=replace-with-a-long-random-string
TEAM_JWT_TTL=12h
AUTHOR_JWT_TTL=7d
# Review-portal link lifetime, in minutes (default 14 days — shared manually, not emailed)
MAGIC_LINK_TTL_MINUTES=20160

# --- Team auth ---
# Comma-separated list of allowed team member emails
TEAM_ALLOWLIST=team@example.com,producer@example.com
# Shared passcode team members enter alongside their allowlisted email —
# no OAuth client needed. Any long random string works.
TEAM_PASSCODE=replace-with-a-shared-passcode

# --- Downloads ---
DOWNLOAD_RATE_LIMIT_WINDOW_MIN=15
DOWNLOAD_RATE_LIMIT_MAX=30
